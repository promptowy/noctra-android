<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@color/bg"
        android:paddingTop="6dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tabBar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingEnd="4dp" />

        <Button
            android:id="@+id/btnNewTab"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:text="+"
            android:textColor="@color/dim"
            android:textSize="20sp"
            android:fontFamily="monospace"
            android:textAllCaps="false"
            android:padding="0dp" />
    </LinearLayout>

    <!-- 1px border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/line" />

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/bg">

        <!-- Logo -->
        <TextView
            android:id="@+id/logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$"
            android:textColor="@color/green"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:paddingEnd="8dp" />

        <!-- Back / Forward -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:text="&lt;"
            android:textColor="@color/fg"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textAllCaps="false"
            android:padding="0dp" />

        <Button
            android:id="@+id/btnForward"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:text="&gt;"
            android:textColor="@color/fg"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textAllCaps="false"
            android:padding="0dp" />

        <!-- URL bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_url_bar"
            android:paddingStart="10dp"
            android:paddingEnd="6dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/lockIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="11sp"
                android:paddingEnd="6dp" />

            <EditText
                android:id="@+id/urlInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:textColor="@color/fg"
                android:textColorHint="@color/dim"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:hint="@string/hint_url"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <Button
                android:id="@+id/btnStar"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@android:color/transparent"
                android:text="☆"
                android:textColor="@color/dim"
                android:textSize="16sp"
                android:padding="0dp"
                android:fontFamily="monospace"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Shield chip -->
        <LinearLayout
            android:id="@+id/chipShield"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_chip"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕ "
                android:textColor="@color/green"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/blockedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/green"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Menu chip -->
        <LinearLayout
            android:id="@+id/chipMenu"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_chip">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="≡"
                android:textColor="@color/fg"
                android:textSize="16sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <!-- 1px border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/line" />

    <!-- WebView container -->
    <FrameLayout
        android:id="@+id/webContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg" />

    <!-- Download tray (hidden by default) -->
    <LinearLayout
        android:id="@+id/downloadTray"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg2"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/dlFilename"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/fg"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:ellipsize="middle"
            android:singleLine="true" />

        <ProgressBar
            android:id="@+id/dlProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="80dp"
            android:layout_height="4dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="100"
            android:progressTint="@color/green"
            android:progressBackgroundTint="@color/line" />

        <TextView
            android:id="@+id/dlStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/green"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/dlDismiss"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:text="×"
            android:textColor="@color/dim"
            android:textSize="14sp"
            android:padding="0dp"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>
