<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_sheet"
    android:paddingBottom="32dp">

    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" android:layout_marginBottom="12dp"
        android:background="@color/line" />

    <Button android:id="@+id/menuNewTab"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackground"
        android:text="+ new tab" android:textColor="@color/fg"
        android:textSize="13sp" android:fontFamily="monospace"
        android:textAllCaps="false" android:gravity="start|center_vertical"
        android:paddingStart="20dp" />

    <Button android:id="@+id/menuBookmarks"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackground"
        android:text="★ bookmarks" android:textColor="@color/fg"
        android:textSize="13sp" android:fontFamily="monospace"
        android:textAllCaps="false" android:gravity="start|center_vertical"
        android:paddingStart="20dp" />

    <Button android:id="@+id/menuProfiles"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackground"
        android:text="◈ profiles" android:textColor="@color/fg"
        android:textSize="13sp" android:fontFamily="monospace"
        android:textAllCaps="false" android:gravity="start|center_vertical"
        android:paddingStart="20dp" />

    <Button android:id="@+id/menuRestoreTab"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackground"
        android:text="⟳ restore closed tab" android:textColor="@color/fg"
        android:textSize="13sp" android:fontFamily="monospace"
        android:textAllCaps="false" android:gravity="start|center_vertical"
        android:paddingStart="20dp" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/line" android:layout_marginTop="4dp" />

    <Button android:id="@+id/menuSettings"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackground"
        android:text="⚙ settings" android:textColor="@color/dim"
        android:textSize="13sp" android:fontFamily="monospace"
        android:textAllCaps="false" android:gravity="start|center_vertical"
        android:paddingStart="20dp" />
</LinearLayout>
