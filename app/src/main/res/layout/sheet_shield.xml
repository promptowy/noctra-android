<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_sheet"
    android:paddingBottom="24dp">

    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" android:layout_marginBottom="12dp"
        android:background="@color/line" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="shield" android:textColor="@color/fg" android:textSize="14sp"
        android:fontFamily="monospace" android:textStyle="bold"
        android:paddingStart="20dp" android:paddingBottom="4dp" />

    <TextView android:id="@+id/shieldSite"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="@color/dim" android:textSize="11sp" android:fontFamily="monospace"
        android:paddingStart="20dp" android:paddingBottom="16dp" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/line" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="14dp" android:paddingBottom="14dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/shieldTabTotal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="@color/green"
                android:textSize="28sp" android:fontFamily="monospace" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="this page" android:textColor="@color/dim"
                android:textSize="10sp" android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/shieldSessionTotal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="@color/fg"
                android:textSize="28sp" android:fontFamily="monospace" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="this session" android:textColor="@color/dim"
                android:textSize="10sp" android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/line" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="# top blocked" android:textColor="@color/dim" android:textSize="11sp"
        android:fontFamily="monospace"
        android:paddingStart="20dp" android:paddingTop="14dp" android:paddingBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/hostList"
        android:layout_width="match_parent"
        android:layout_height="192dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clipToPadding="false" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/line" android:layout_marginTop="16dp" />

    <Button android:id="@+id/btnToggleShield"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:layout_marginStart="20dp" android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_chip"
        android:text="disable shield on this site"
        android:textColor="@color/red" android:textSize="12sp"
        android:fontFamily="monospace" android:textAllCaps="false" />
</LinearLayout>
